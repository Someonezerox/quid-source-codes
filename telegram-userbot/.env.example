# Get api_id / api_hash from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Where this sidecar pushes inbound messages
BACKEND_URL=http://localhost:8080

# Shared secret between the Java backend and this sidecar (set the same value on both)
INTERNAL_TOKEN=change-me

# Where StringSessions are stored (gitignored)
SESSIONS_DIR=./sessions
